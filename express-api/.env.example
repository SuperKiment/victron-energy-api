# =============================================================================
# Victron Energy API — Configuration
# =============================================================================
# Copiez ce fichier en .env et remplissez vos valeurs

# --- Mode de connexion ---
# "modbus"  → connexion locale via Modbus TCP (réseau LAN)
# "vrm"     → connexion distante via le portail VRM (internet)
# "both"    → les deux sources sont disponibles (Modbus prioritaire)
CONNECTION_MODE=modbus

# =============================================================================
# MODBUS TCP — Connexion locale (réseau LAN)
# =============================================================================
# Adresse IP de votre MultiPlus-II GX (trouvez-la dans : Paramètres → Wi-Fi)
MODBUS_HOST=192.168.1.100

# Port Modbus TCP (défaut : 502)
MODBUS_PORT=502

# Délai de connexion en ms
MODBUS_TIMEOUT=5000

# Unit-ID du système global (toujours 100)
MODBUS_UNIT_SYSTEM=100

# Unit-ID du MultiPlus-II (VE.Bus)
# À vérifier dans : Paramètres → Services → Modbus TCP → Services disponibles
# Valeur typique : 227, 238, 242, 246 selon l'installation
MODBUS_UNIT_VEBUS=246

# =============================================================================
# VRM API — Connexion distante (cloud Victron)
# =============================================================================
# Vos identifiants du portail VRM (https://vrm.victronenergy.com)
VRM_EMAIL=votre@email.com
VRM_PASSWORD=votre_mot_de_passe

# Identifiant de l'installation VRM
# Visible dans l'URL : https://vrm.victronenergy.com/installation/XXXXX/
VRM_SITE_ID=123456

# =============================================================================
# Serveur Express
# =============================================================================
PORT=3000

# Intervalle de mise en cache des données Modbus (ms) — évite de surcharger l'appareil
CACHE_TTL_MS=5000
